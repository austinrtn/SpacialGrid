<mxfile host="app.diagrams.net">
  <diagram name="insert()">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="insert(ids, positions)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="260" height="40" as="geometry" />
        </mxCell>

        <!-- START -->
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a3a6b;strokeColor=#4d9de0;strokeWidth=2;fontSize=13;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="455" y="80" width="110" height="50" as="geometry" />
        </mxCell>

        <!-- Reset counts -->
        <mxCell id="reset" value="@memset(counts, 0)&#xa;Reset all cell counts to zero" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5c3d00;strokeColor=#e6a817;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="405" y="170" width="210" height="55" as="geometry" />
        </mxCell>

        <!-- Loop 1 header -->
        <mxCell id="loop1_label" value="Pass 1 — Count entities per cell" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=3;fontColor=#aaaaaa;" vertex="1" parent="1">
          <mxGeometry x="390" y="255" width="240" height="25" as="geometry" />
        </mxCell>

        <!-- Loop 1: for each position -->
        <mxCell id="loop1" value="For each pos in positions" style="rhombus;whiteSpace=wrap;html=1;fillColor=#5c0f0f;strokeColor=#cc3333;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="290" width="190" height="65" as="geometry" />
        </mxCell>

        <!-- getCellPos -->
        <mxCell id="getcell1" value="getCellPos(pos)&#xa;→ cell.idx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5c3d00;strokeColor=#e6a817;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="390" width="190" height="50" as="geometry" />
        </mxCell>

        <!-- out of bounds check -->
        <mxCell id="oob1" value="OutOfBounds?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#5c0f0f;strokeColor=#cc3333;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="465" width="190" height="55" as="geometry" />
        </mxCell>

        <!-- skip -->
        <mxCell id="skip1" value="continue&#xa;(skip entity)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2e2e;strokeColor=#888888;strokeWidth=2;fontSize=11;fontColor=#aaaaaa;" vertex="1" parent="1">
          <mxGeometry x="650" y="470" width="120" height="45" as="geometry" />
        </mxCell>

        <!-- increment count -->
        <mxCell id="incr" value="counts[cell.idx] += 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3d1a;strokeColor=#33aa55;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="550" width="190" height="45" as="geometry" />
        </mxCell>

        <!-- After loop 1: state note -->
        <mxCell id="state1" value="counts[i] = number of entities in cell i" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#1e2d40;strokeColor=#4a7aaa;strokeWidth=2;fontSize=11;fontColor=#cce4ff;" vertex="1" parent="1">
          <mxGeometry x="640" y="548" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- Pass 2 header -->
        <mxCell id="loop2_label" value="Pass 2 — Prefix sum (convert counts to start offsets)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=3;fontColor=#aaaaaa;" vertex="1" parent="1">
          <mxGeometry x="355" y="625" width="310" height="25" as="geometry" />
        </mxCell>

        <!-- Loop 2 -->
        <mxCell id="loop2" value="For each *count in counts" style="rhombus;whiteSpace=wrap;html=1;fillColor=#5c0f0f;strokeColor=#cc3333;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="660" width="190" height="65" as="geometry" />
        </mxCell>

        <!-- prefix sum body -->
        <mxCell id="prefix" value="placeholder = count.*&#xa;count.* = total&#xa;total += placeholder" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3d1a;strokeColor=#33aa55;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="755" width="190" height="60" as="geometry" />
        </mxCell>

        <!-- After loop 2: state note -->
        <mxCell id="state2" value="counts[i] = start index of cell i in indices[]" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#1e2d40;strokeColor=#4a7aaa;strokeWidth=2;fontSize=11;fontColor=#cce4ff;" vertex="1" parent="1">
          <mxGeometry x="640" y="760" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- Pass 3 header -->
        <mxCell id="loop3_label" value="Pass 3 — Scatter entities into indices[]" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=3;fontColor=#aaaaaa;" vertex="1" parent="1">
          <mxGeometry x="370" y="840" width="280" height="25" as="geometry" />
        </mxCell>

        <!-- Loop 3 -->
        <mxCell id="loop3" value="For each (pos, id) in&#xa;zip(positions, ids)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#5c0f0f;strokeColor=#cc3333;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="875" width="190" height="65" as="geometry" />
        </mxCell>

        <!-- getCellPos again -->
        <mxCell id="getcell2" value="getCellPos(pos)&#xa;→ cell.idx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5c3d00;strokeColor=#e6a817;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="970" width="190" height="50" as="geometry" />
        </mxCell>

        <!-- oob2 -->
        <mxCell id="oob2" value="OutOfBounds?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#5c0f0f;strokeColor=#cc3333;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="1045" width="190" height="55" as="geometry" />
        </mxCell>

        <!-- skip2 -->
        <mxCell id="skip2" value="continue&#xa;(skip entity)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e2e2e;strokeColor=#888888;strokeWidth=2;fontSize=11;fontColor=#aaaaaa;" vertex="1" parent="1">
          <mxGeometry x="650" y="1050" width="120" height="45" as="geometry" />
        </mxCell>

        <!-- scatter body -->
        <mxCell id="scatter" value="cursor = &amp;counts[cell.idx]&#xa;indices[cursor.*] = id&#xa;cursor.* += 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3d1a;strokeColor=#33aa55;strokeWidth=2;fontSize=12;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="1128" width="190" height="60" as="geometry" />
        </mxCell>

        <!-- After loop 3: state note -->
        <mxCell id="state3" value="indices[] is now a flat array of entity ids,&#xa;grouped contiguously by cell.&#xa;counts[i] = one-past-end of cell i." style="shape=callout;whiteSpace=wrap;html=1;fillColor=#1e2d40;strokeColor=#4a7aaa;strokeWidth=2;fontSize=11;fontColor=#cce4ff;" vertex="1" parent="1">
          <mxGeometry x="630" y="1128" width="240" height="65" as="geometry" />
        </mxCell>

        <!-- END -->
        <mxCell id="end" value="End" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a3a6b;strokeColor=#4d9de0;strokeWidth=2;fontSize=13;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="455" y="1220" width="110" height="50" as="geometry" />
        </mxCell>

        <!-- ── Edges ── -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="start" target="reset" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="reset" target="loop1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="more" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="loop1" target="getcell1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3b" value="done" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="loop1" target="loop2_label" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="770" y="323" /><mxPoint x="770" y="638" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="getcell1" target="oob1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="yes" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="oob1" target="skip1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5b" value="no" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="oob1" target="incr" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="incr" target="loop1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="370" y="573" /><mxPoint x="370" y="323" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e6b" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="skip1" target="loop1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="810" y="493" /><mxPoint x="810" y="323" /></Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="loop2_label" target="loop2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="more" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="loop2" target="prefix" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8b" value="done" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="loop2" target="loop3_label" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="770" y="693" /><mxPoint x="770" y="853" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="prefix" target="loop2" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="370" y="785" /><mxPoint x="370" y="693" /></Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="loop3_label" target="loop3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" value="more" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="loop3" target="getcell2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11b" value="done" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="loop3" target="end" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="770" y="908" /><mxPoint x="770" y="1245" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="getcell2" target="oob2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" value="yes" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="oob2" target="skip2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" value="no" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="oob2" target="scatter" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="scatter" target="loop3" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="370" y="1158" /><mxPoint x="370" y="908" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e15b" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="skip2" target="loop3" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="810" y="1073" /><mxPoint x="810" y="908" /></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#cccccc;fontColor=#cccccc;" edge="1" source="scatter" target="end" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="510" y="1200" /></Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
